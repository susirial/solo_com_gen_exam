<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ paper.title }} - 学生版</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif; margin: 32px; color: #222; line-height: 1.8; }
    h1, h2 { margin-bottom: 8px; }
    .meta { margin-bottom: 24px; color: #555; }
    .section { margin: 28px 0; page-break-inside: avoid; }
    .instructions { color: #666; margin-bottom: 12px; }
    .question { border-top: 1px solid #ddd; padding: 18px 0; }
    .stem { font-weight: 600; }
    .options { margin: 12px 0 0 20px; }
    .material { background: #fafafa; border-left: 4px solid #d0d7de; padding: 12px; margin: 12px 0; white-space: pre-wrap; }
    .answer-space { margin-top: 14px; min-height: 72px; border-bottom: 1px dashed #bbb; }
    .pill { display: inline-block; padding: 2px 8px; border-radius: 999px; background: #f1f3f5; margin-right: 8px; font-size: 12px; }
  </style>
</head>
<body>
  <h1>{{ paper.title }}</h1>
  <div class="meta">
    <span class="pill">{{ paper.meta.stage }}</span>
    <span class="pill">{{ paper.meta.grade }}</span>
    <span class="pill">{{ paper.meta.subject }}</span>
    <span class="pill">{{ paper.meta.exam_type }}</span>
    <span class="pill">时长 {{ paper.meta.duration_minutes }} 分钟</span>
    <span class="pill">总分 {{ paper.meta.total_score }}</span>
  </div>

  {% for section in paper.sections %}
  <section class="section">
    <h2>{{ section.title }}</h2>
    <div class="instructions">{{ section.instructions }}</div>
    {% if section.shared_material %}
    <div class="material">{{ section.shared_material }}</div>
    {% endif %}

    {% for question in section.questions %}
    <article class="question">
      <div class="stem">{{ loop.index }}. {{ question.stem }} （{{ question.score }} 分）</div>
      {% if question.options %}
      <ol class="options" type="A">
        {% for option in question.options %}
        <li>{{ option }}</li>
        {% endfor %}
      </ol>
      {% else %}
      <div class="answer-space"></div>
      {% endif %}
    </article>
    {% endfor %}
  </section>
  {% endfor %}
</body>
</html>
